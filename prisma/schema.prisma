// ============================================================
// FXDE v5.1 — Prisma Schema (Canonical DB Definition)
// DO NOT modify columns/types/relations without a change proposal.
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────

enum UserRole {
  FREE
  BASIC
  PRO
  PRO_PLUS
  ADMIN
}

enum TradeDirection {
  LONG
  SHORT
}

enum TradeStatus {
  OPEN
  CLOSED
}

enum PredictionStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
}

// ─── Users ───────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         UserRole @default(FREE)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  settings Settings?
  trades   Trade[]
}

// ─── Settings ────────────────────────────────────────────────

model Settings {
  id        String   @id @default(uuid())
  userId    String   @unique
  timezone  String   @default("UTC")
  riskLimit Float?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

// ─── Symbols ─────────────────────────────────────────────────

model Symbol {
  id        String   @id @default(uuid())
  name      String   @unique
  base      String
  quote     String
  createdAt DateTime @default(now())

  trades Trade[]
}

// ─── Trades ──────────────────────────────────────────────────

model Trade {
  id         String         @id @default(uuid())
  userId     String
  symbolId   String
  direction  TradeDirection
  entryPrice Float
  exitPrice  Float?
  volume     Float
  entryTime  DateTime
  exitTime   DateTime?
  status     TradeStatus    @default(OPEN)
  profit     Float?
  note       String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  user    User          @relation(fields: [userId], references: [id])
  symbol  Symbol        @relation(fields: [symbolId], references: [id])
  reviews TradeReview[]
}

// ─── Trade Review / Journal ───────────────────────────────────

model TradeReview {
  id        String   @id @default(uuid())
  tradeId   String
  emotion   String?
  reason    String?
  lesson    String?
  createdAt DateTime @default(now())

  trade Trade @relation(fields: [tradeId], references: [id])
}

// ─── Snapshots (Analytics) ───────────────────────────────────

model Snapshot {
  id        String   @id @default(uuid())
  userId    String
  metric    String
  value     Float
  createdAt DateTime @default(now())
}

// ─── Signals ─────────────────────────────────────────────────

model Signal {
  id         String   @id @default(uuid())
  symbolId   String
  type       String
  confidence Float
  createdAt  DateTime @default(now())
}

// ─── Connectors ──────────────────────────────────────────────

model Connector {
  id        String   @id @default(uuid())
  name      String   @unique
  status    String
  updatedAt DateTime @updatedAt
}

// ─── Prediction (stub) ───────────────────────────────────────

model PredictionJob {
  id        String           @id @default(uuid())
  userId    String
  symbolId  String
  timeframe String
  status    PredictionStatus @default(PENDING)
  createdAt DateTime         @default(now())

  results PredictionResult[]
}

model PredictionResult {
  id         String   @id @default(uuid())
  jobId      String
  resultData Json
  createdAt  DateTime @default(now())

  job PredictionJob @relation(fields: [jobId], references: [id])
}

// ─── Market Candles ──────────────────────────────────────────

model MarketCandle {
  id        String   @id @default(uuid())
  symbolId  String
  timeframe String
  open      Float
  high      Float
  low       Float
  close     Float
  volume    Float
  time      DateTime

  @@index([symbolId, timeframe, time])
}

// ─── Indicator Cache ─────────────────────────────────────────

model IndicatorCache {
  id        String   @id @default(uuid())
  symbolId  String
  timeframe String
  indicator String
  data      Json
  createdAt DateTime @default(now())

  @@index([symbolId, timeframe])
}

// ─── Pattern Detection ───────────────────────────────────────

model PatternDetection {
  id         String   @id @default(uuid())
  symbolId   String
  timeframe  String
  pattern    String
  confidence Float
  detectedAt DateTime

  @@index([symbolId, timeframe])
}

// ─── Chart Snapshot ──────────────────────────────────────────

model ChartSnapshot {
  id        String   @id @default(uuid())
  symbolId  String
  timeframe String
  imageUrl  String
  createdAt DateTime @default(now())
}
