// ============================================================
// FXDE v5.1 — Prisma Schema（DB 契約正本）
// 正本: SPEC_v51_part2.md §2 + SPEC_v51_part11.md §6
// Part 10 が Part 1〜9 より優先。Part 11 が Chart 専用テーブルの正本。
//
// 命名規約（厳守）:
//   Prisma model 名 / field 名 : PascalCase / camelCase
//   DB table 名 / column 名    : snake_case（@@map / @map で変換）
//   enum 名                    : PascalCase
//   enum 値                    : 仕様書どおり（勝手に変更しない）
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS（SPEC Part 2 §2 準拠）
// ============================================================

enum UserRole {
  FREE
  BASIC
  PRO
  PRO_PLUS
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum Preset {
  conservative
  standard
  aggressive
}

enum TradeSide {
  BUY
  SELL
}

enum TradeStatus {
  OPEN
  CLOSED
  CANCELED
}

enum EntryState {
  ENTRY_OK
  SCORE_LOW
  RISK_NG
  LOCKED
  COOLDOWN
}

enum Timeframe {
  M1
  M5
  M15
  M30
  H1
  H4
  H8
  D1
  W1
  MN
}

enum JobStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
}

enum SignalType {
  ENTRY_OK
  LOCKED_EVENT
  LOCKED_FORCE
  COOLDOWN
  BREAKOUT
  PATTERN_DETECTED
}

enum ImportanceLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// ============================================================
// Plugin System Enums
// ============================================================

enum PluginType {
  pattern
  indicator
  strategy
  risk
  overlay
  signal
  ai
  connector
}

enum PluginStatus {
  enabled
  disabled
  error
  incompatible
  missing_dependency
  update_available
}

enum PluginInstallScope {
  system
  user
}

// ============================================================
// 認証 / ユーザー
// ============================================================

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String     @map("password_hash")
  role         UserRole   @default(FREE)
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt      @map("updated_at")
  lastLoginAt  DateTime?                  @map("last_login_at")

  // relations
  sessions          Session[]
  settings          UserSetting?
  symbolSettings    SymbolSetting[]
  trades            Trade[]
  snapshots         Snapshot[]
  signals           Signal[]
  predictionJobs    PredictionJob[]
  auditLogs         AuditLog[]
  patternDetections PatternDetection[]
  chartSnapshots    ChartSnapshot[]
  aiSummaries       AiSummary[]

  @@map("users")
}

model Session {
  id               String    @id @default(uuid())
  userId           String    @map("user_id")
  refreshTokenHash String    @map("refresh_token_hash")
  userAgent        String?   @map("user_agent")
  ipAddress        String?   @map("ip_address")
  expiresAt        DateTime  @map("expires_at")
  revokedAt        DateTime? @map("revoked_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

// ============================================================
// 設定
// ============================================================

model UserSetting {
  id             String  @id @default(uuid())
  userId         String  @unique @map("user_id")
  preset         Preset  @default(standard)
  scoreThreshold Int     @default(75) @map("score_threshold")

  // riskProfile JSONB 構造:
  // { maxRiskPct, maxDailyLossPct, maxStreak, cooldownMin, maxTrades, atrMultiplier }
  riskProfile Json @default("{}") @map("risk_profile")

  // uiPrefs JSONB 構造:
  // { theme: "dark"|"light", mode: "beginner"|"pro", defaultSymbol, defaultTimeframe }
  uiPrefs Json @default("{}") @map("ui_prefs")

  // featureSwitches JSONB 構造:
  // { aiSignal, patternBonus, newsLock, cooldownTimer, mtfPrediction }
  featureSwitches Json    @default("{}") @map("feature_switches")
  forceLock       Boolean @default(false) @map("force_lock")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

model SymbolSetting {
  id               String    @id @default(uuid())
  userId           String    @map("user_id")
  symbol           String
  enabled          Boolean   @default(true)
  defaultTimeframe Timeframe @default(H4) @map("default_timeframe")
  customThreshold  Int?      @map("custom_threshold")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt      @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, symbol])
  @@map("symbol_settings")
}

// ============================================================
// トレード記録
// ============================================================

model Trade {
  id         String      @id @default(uuid())
  userId     String      @map("user_id")
  symbol     String
  side       TradeSide
  entryTime  DateTime    @map("entry_time")
  entryPrice Decimal     @map("entry_price") @db.Decimal(10, 5)
  exitTime   DateTime?   @map("exit_time")
  exitPrice  Decimal?    @map("exit_price")  @db.Decimal(10, 5)
  size       Decimal     @db.Decimal(10, 4)
  sl         Decimal?    @db.Decimal(10, 5)
  tp         Decimal?    @db.Decimal(10, 5)
  pnl        Decimal?    @db.Decimal(12, 2)
  pips       Decimal?    @db.Decimal(8, 1)
  status     TradeStatus @default(OPEN)
  tags       String[]    @default([])
  note       String?
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt      @map("updated_at")

  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  review TradeReview?

  @@index([userId, status])
  @@index([userId, symbol])
  @@index([userId, entryTime])
  @@map("trades")
}

model TradeReview {
  id           String   @id @default(uuid())
  tradeId      String   @unique @map("trade_id")
  scoreAtEntry Int      @map("score_at_entry")

  // ruleChecks JSONB 構造:
  // { scoreOk, riskOk, eventLock, cooldown, patterns: string[], entryState }
  ruleChecks Json @map("rule_checks")

  // psychology JSONB 構造:
  // { emotion, selfNote, biasDetected: string[] }
  psychology  Json     @default("{}") @map("psychology")
  disciplined Boolean
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt      @map("updated_at")

  trade Trade @relation(fields: [tradeId], references: [id], onDelete: Cascade)

  @@map("trade_reviews")
}

// ============================================================
// スナップショット / スコア
// ============================================================

model Snapshot {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  symbol    String
  timeframe Timeframe
  capturedAt DateTime @map("captured_at")

  // indicators JSONB 構造:
  // { ma, rsi, macd, bb, atr }
  indicators Json

  // patterns 配列要素: { name, direction, confidence, bonus }
  patterns Json @default("[]")

  // mtfAlignment 構造: { W1: { score, direction }, D1: {...}, ... }
  mtfAlignment Json @default("{}") @map("mtf_alignment")

  scoreTotal     Int        @map("score_total")

  // scoreBreakdown 構造: { technical, fundamental, market, rr, patternBonus }
  scoreBreakdown Json @map("score_breakdown")

  entryState EntryState @map("entry_state")

  // entryContext 構造: { rr, lotSize, isEventWindow, isCooldown, forceLock }
  entryContext Json @map("entry_context")

  createdAt DateTime @default(now()) @map("created_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  signals Signal[]

  @@index([userId, symbol, capturedAt])
  @@index([userId, entryState])
  @@map("snapshots")
}

// ============================================================
// シグナル
// ============================================================

model Signal {
  id          String     @id @default(uuid())
  userId      String     @map("user_id")
  symbol      String
  timeframe   Timeframe
  snapshotId  String     @map("snapshot_id")
  triggeredAt DateTime   @map("triggered_at")
  type        SignalType

  // metadata JSONB 構造（SignalType 別）:
  // ENTRY_OK:         { score, patterns }
  // LOCKED_EVENT:     { eventName, minutesUntil }
  // PATTERN_DETECTED: { patternName, confidence, bonus }
  metadata       Json      @default("{}")
  acknowledgedAt DateTime? @map("acknowledged_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  snapshot Snapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@index([userId, acknowledgedAt])
  @@index([userId, triggeredAt])
  @@map("signals")
}

// ============================================================
// MTF 予測（v5.1 = stub のみ）
// ============================================================

model PredictionJob {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  symbol       String
  timeframe    Timeframe

  // requestData JSONB 構造（v5.1 はジョブ受付・状態管理のみ）:
  // { symbol: string, timeframe: Timeframe }
  requestData  Json      @map("request_data")

  status       JobStatus @default(QUEUED)
  startedAt    DateTime? @map("started_at")
  finishedAt   DateTime? @map("finished_at")
  errorMessage String?   @map("error_message")
  createdAt    DateTime  @default(now()) @map("created_at")

  user   User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  result PredictionResult?

  @@index([userId, status])
  @@index([userId, createdAt])
  @@map("prediction_jobs")
}

model PredictionResult {
  id        String   @id @default(uuid())
  jobId     String   @unique @map("job_id")

  // resultData JSONB 構造（v5.1 = STUB_PREDICTION_RESULT 固定値）:
  // {
  //   scenarios: {
  //     bull:    { probability: 0.42, target: '+0.8%', horizonBars: 12 },
  //     neutral: { probability: 0.33, target: '+0.1%', horizonBars: 12 },
  //     bear:    { probability: 0.25, target: '-0.5%', horizonBars: 12 },
  //   },
  //   stats: { matchedCases: 0, confidence: 0.55, note: 'v5.1 STUB result' },
  //   tfWeights: null,
  //   hmmState:  null,
  // }
  resultData Json     @map("result_data")
  createdAt  DateTime @default(now()) @map("created_at")

  job PredictionJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("prediction_results")
}

// ============================================================
// 共有マスタ（ユーザー非依存）
// ============================================================

model InterestRate {
  id          String   @id @default(uuid())
  country     String
  bank        String
  currency    String
  rate        Decimal  @db.Decimal(5, 3)
  effectiveAt DateTime @map("effective_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([currency, effectiveAt])
  @@map("interest_rates")
}

model EconomicEvent {
  id          String          @id @default(uuid())
  title       String
  country     String
  currency    String
  scheduledAt DateTime        @map("scheduled_at")
  importance  ImportanceLevel
  actual      Decimal?        @db.Decimal(10, 4)
  forecast    Decimal?        @db.Decimal(10, 4)
  previous    Decimal?        @db.Decimal(10, 4)
  deviation   Decimal?        @db.Decimal(10, 4)
  source      String?
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt      @map("updated_at")

  @@index([scheduledAt, importance])
  @@index([currency, scheduledAt])
  @@map("economic_events")
}

// ============================================================
// 監査ログ（ADMIN 専用）
// ============================================================

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  action     String
  targetType String?  @map("target_type")
  targetId   String?  @map("target_id")
  metadata   Json     @default("{}")
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@map("audit_logs")
}

// ============================================================
// AI 要約（SPEC_v51_part4 §6）
// ============================================================

model AiSummary {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  symbol    String
  text      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, symbol])
  @@index([userId, createdAt])
  @@map("ai_summaries")
}

// ============================================================
// Chart 専用テーブル（SPEC Part 11 §6 正本）
// PG-07 Chart ページ専用。コアテーブルと役割を明確に分離。
// ============================================================
// v5.1 実装許可（Part 11 §9.1 参照）:
//   market_candles    : ローソク足 OHLCV キャッシュ（ユーザー非依存）
//   indicator_cache   : インジケーター計算結果キャッシュ（ユーザー非依存）
//   pattern_detections: チャートパターン検出ログ（ユーザー別）
//   chart_snapshots   : チャート状態スナップショット（ユーザー別）
//
// v5.1 禁止（Part 11 §9.2 参照）:
//   chart-notes の DB 永続化（notes = null 固定）
//   chart_snapshots.trade_id へのトレード接続（trade_id = null 固定）

/// ローソク足 OHLCV キャッシュ（ユーザー非依存・共有テーブル）
model MarketCandle {
  id        String    @id @default(uuid())
  symbol    String    @db.VarChar(10)
  timeframe Timeframe
  time      DateTime  @db.Timestamptz(6)
  open      Decimal   @db.Decimal(18, 6)
  high      Decimal   @db.Decimal(18, 6)
  low       Decimal   @db.Decimal(18, 6)
  close     Decimal   @db.Decimal(18, 6)
  volume    BigInt
  source    String    @db.VarChar(50)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt      @map("updated_at")

  @@unique([symbol, timeframe, time])
  @@index([symbol, timeframe, time(sort: Desc)])
  @@map("market_candles")
}

/// インジケーター計算結果キャッシュ（ユーザー非依存・共有テーブル）
model IndicatorCache {
  id           String    @id @default(uuid())
  symbol       String    @db.VarChar(10)
  timeframe    Timeframe
  calculatedAt DateTime  @map("calculated_at") @db.Timestamptz(6)

  // indicators JSONB: IndicatorSet 型（Part 11 §3.3 準拠）
  // { ma, rsi, macd, atr, bb, bias }
  indicators   Json

  source       String    @db.VarChar(50)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt      @map("updated_at")

  @@index([symbol, timeframe, calculatedAt(sort: Desc)])
  @@index([calculatedAt])
  @@map("indicator_cache")
}

/// チャートパターン検出ログ（ユーザー別）
/// patternName: Part 6 §1.0 正式名称のみ使用する
/// patternCategory: "CANDLESTICK"（6種）または "FORMATION"（6種）
model PatternDetection {
  id              String    @id @default(uuid())
  userId          String    @map("user_id")
  symbol          String    @db.VarChar(10)
  timeframe       Timeframe
  patternName     String    @map("pattern_name")     @db.VarChar(100)
  patternCategory String    @map("pattern_category") @db.VarChar(20)
  direction       String    @db.VarChar(10)
  confidence      Decimal   @db.Decimal(5, 4)
  detectedAt      DateTime  @map("detected_at") @db.Timestamptz(6)
  barIndex        Int       @map("bar_index")
  price           Decimal   @db.Decimal(18, 6)
  label           String    @db.VarChar(50)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt      @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, symbol, timeframe, detectedAt(sort: Desc)])
  @@index([userId, detectedAt(sort: Desc)])
  @@map("pattern_detections")
}

/// チャート状態スナップショット（ユーザー別）
/// v5.1: テーブル定義のみ。chart-notes 永続化は v6 で実装（notes = null 固定）
/// v5.1: trade_id = null 固定。v6 でトレード記録 CRUD と接続する。
model ChartSnapshot {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  symbol       String    @db.VarChar(10)
  timeframe    Timeframe
  capturedAt   DateTime  @map("captured_at") @db.Timestamptz(6)

  // chartConfig JSONB: { indicators, overlays, chartType }
  chartConfig  Json      @map("chart_config")

  // overlayState JSONB: { entryPrice, stopLoss, takeProfit }
  overlayState Json      @map("overlay_state")

  // v5.1 = null 固定 / v6 で永続化
  notes        String?

  // v5.1 = null 固定 / v6 でトレード記録 CRUD と接続
  tradeId      String?   @map("trade_id")

  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt      @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, symbol, capturedAt(sort: Desc)])
  @@index([userId, capturedAt(sort: Desc)])
  @@map("chart_snapshots")
}

// ============================================================
// Plugin System Models
// ============================================================

/// プラグイン定義情報（manifest の正本）
model PluginManifest {
  id               String             @id @default(cuid())
  slug             String             @unique @db.VarChar(191)
  displayName      String             @map("display_name") @db.VarChar(191)
  version          String             @db.VarChar(64)
  descriptionShort String             @map("description_short") @db.VarChar(300)
  descriptionLong  String             @map("description_long") @db.Text
  pluginType       PluginType         @map("plugin_type")
  authorName       String             @map("author_name") @db.VarChar(191)
  sourceLabel      String             @map("source_label") @db.VarChar(191)
  homepageUrl      String?            @map("homepage_url") @db.VarChar(500)
  docsUrl          String?            @map("docs_url") @db.VarChar(500)
  coverImageUrl    String?            @map("cover_image_url") @db.VarChar(500)
  iconUrl          String?            @map("icon_url") @db.VarChar(500)
  readmeMarkdown   String?            @map("readme_markdown") @db.Text
  sourcePreview    String?            @map("source_preview") @db.Text
  entryFile        String             @map("entry_file") @db.VarChar(500)
  checksum         String             @db.VarChar(191)
  fxdeApiVersion   String             @map("fxde_api_version") @db.VarChar(64)
  fxdeWebVersion   String             @map("fxde_web_version") @db.VarChar(64)
  // JSONB 配列フィールド（string[]）
  capabilitiesJson Json               @map("capabilities_json")
  permissionsJson  Json               @map("permissions_json")
  dependenciesJson Json               @map("dependencies_json")
  optionalDepsJson Json               @map("optional_deps_json")
  tagsJson         Json               @map("tags_json")
  isCore           Boolean            @default(false) @map("is_core")
  isSigned         Boolean            @default(false) @map("is_signed")
  installScope     PluginInstallScope @default(system) @map("install_scope")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt      @map("updated_at")

  // relations
  installedPlugins InstalledPlugin[]
  auditLogs        PluginAuditLog[]

  @@index([pluginType])
  @@index([isCore])
  @@map("plugin_manifests")
}

/// 実際に利用中のプラグイン状態
model InstalledPlugin {
  id                 String       @id @default(cuid())
  pluginManifestId   String       @unique @map("plugin_manifest_id")
  installedByUserId  String?      @map("installed_by_user_id")
  isEnabled          Boolean      @default(false) @map("is_enabled")
  status             PluginStatus @default(disabled)
  errorMessage       String?      @map("error_message") @db.Text
  configLocked       Boolean      @default(true) @map("config_locked")
  installedAt        DateTime     @default(now()) @map("installed_at")
  enableUpdatedAt    DateTime     @default(now()) @map("enable_updated_at")
  lastHealthCheckAt  DateTime?    @map("last_health_check_at")
  lastExecutedAt     DateTime?    @map("last_executed_at")

  pluginManifest PluginManifest @relation(fields: [pluginManifestId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([isEnabled])
  @@map("installed_plugins")
}

/// plugin enable / disable 等の監査ログ
model PluginAuditLog {
  id               String   @id @default(cuid())
  pluginManifestId String   @map("plugin_manifest_id")
  actorUserId      String?  @map("actor_user_id")
  action           String   @db.VarChar(64)
  beforeStateJson  Json     @map("before_state_json")
  afterStateJson   Json     @map("after_state_json")
  createdAt        DateTime @default(now()) @map("created_at")

  pluginManifest PluginManifest @relation(fields: [pluginManifestId], references: [id], onDelete: Cascade)

  @@index([pluginManifestId, createdAt])
  @@map("plugin_audit_logs")
}

// ============================================================
// Adaptive Plugin Ranking Engine Models
// (fxde_plugin_ranking_engine §3)
// ============================================================

/// Plugin が出力した signal / overlay のイベントログ
model PluginEvent {
  id         String   @id @default(uuid())
  pluginKey  String   @map("plugin_key")
  symbol     String   @db.VarChar(10)
  timeframe  String   @db.VarChar(10)
  eventType  String   @map("event_type") @db.VarChar(20)  // "signal" | "overlay" | "indicator"
  direction  String?  @db.VarChar(10)                     // "BUY" | "SELL" | "NEUTRAL"
  price      Float?
  confidence Float?
  metadata   Json?
  emittedAt  DateTime @map("emitted_at")
  createdAt  DateTime @default(now()) @map("created_at")

  results PluginEventResult[]

  @@index([pluginKey, symbol, timeframe, emittedAt(sort: Desc)])
  @@index([emittedAt])
  @@map("plugin_events")
}

/// Plugin event の事後損益評価結果
model PluginEventResult {
  id           String   @id @default(uuid())
  eventId      String   @map("event_id")
  candleOffset Int      @map("candle_offset")  // 1, 3, 5, 10, 20
  priceChange  Float    @map("price_change")
  returnPct    Float    @map("return_pct")
  mfe          Float                            // Maximum Favorable Excursion
  mae          Float                            // Maximum Adverse Excursion
  resultPips   Float?   @map("result_pips")
  evaluatedAt  DateTime @default(now()) @map("evaluated_at")

  event PluginEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@map("plugin_event_results")
}

/// Plugin ごとの集計信頼度スコア
model PluginReliability {
  id               String   @id @default(uuid())
  pluginKey        String   @map("plugin_key")
  symbol           String?  @db.VarChar(10)
  timeframe        String?  @db.VarChar(10)
  sampleSize       Int      @map("sample_size")
  winRate          Float    @map("win_rate")
  expectancy       Float
  avgReturn        Float    @map("avg_return")
  avgMfe           Float    @map("avg_mfe")
  avgMae           Float    @map("avg_mae")
  reliabilityScore Float    @map("reliability_score")
  stabilityScore   Float    @map("stability_score")
  confidenceScore  Float    @map("confidence_score")
  state            String   @db.VarChar(20)  // "active" | "demoted" | "suppressed" | "stop_candidate"
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@index([pluginKey, symbol, timeframe])
  @@map("plugin_reliability")
}

/// Plugin ランキング決定履歴
model PluginAdaptiveDecision {
  id              String   @id @default(uuid())
  pluginKey       String   @map("plugin_key")
  symbol          String?  @db.VarChar(10)
  timeframe       String?  @db.VarChar(10)
  contextHash     String?  @map("context_hash")
  globalScore     Float    @map("global_score")
  contextualScore Float    @map("contextual_score")
  finalRankScore  Float    @map("final_rank_score")
  rankPosition    Int      @map("rank_position")
  action          String   @db.VarChar(20)  // "keep" | "demote" | "suppress" | "auto_stop"
  reasonCodes     Json?    @map("reason_codes")
  decidedAt       DateTime @map("decided_at")

  @@index([pluginKey, decidedAt(sort: Desc)])
  @@map("plugin_adaptive_decisions")
}

/// Plugin の条件別集計スコア（v1 skeleton: aggregation は未実装）
/// 完全設計書 §ConditionStats に基づく骨格定義。
/// 集計処理は v2 で追加予定。
model PluginConditionStats {
  id           String   @id @default(uuid())
  pluginKey    String   @map("plugin_key")
  conditionKey String   @map("condition_key")  // 例: "session:london" / "symbol:USDJPY" / "trend:bullish"
  sampleCount  Int      @default(0) @map("sample_count")
  winRate      Float    @default(0) @map("win_rate")
  avgReturn    Float    @default(0) @map("avg_return")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@unique([pluginKey, conditionKey])
  @@index([pluginKey])
  @@map("plugin_condition_stats")
}