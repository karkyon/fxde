# =============================================================================
# FXDE API Environment Template
# -----------------------------------------------------------------------------
# NestJS API が使用する環境変数テンプレート
#
# 使用方法
#   cp .env.example .env
# =============================================================================


# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://fxde:fxde_password@localhost:5436/fxde_db"


# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
# BullMQ / queue 接続
REDIS_URL=redis://localhost:6386


# -----------------------------------------------------------------------------
# API Server
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3011
API_PREFIX=/api/v1


# -----------------------------------------------------------------------------
# JWT
# -----------------------------------------------------------------------------
JWT_SECRET=replace_this_with_secure_value
JWT_EXPIRES_IN=15m

JWT_REFRESH_SECRET=replace_this_with_secure_value
REFRESH_TOKEN_EXPIRES_IN=7d


# -----------------------------------------------------------------------------
# Frontend origin
# -----------------------------------------------------------------------------
FRONTEND_URL=http://localhost:5173


# -----------------------------------------------------------------------------
# AI Summary (optional)
# -----------------------------------------------------------------------------
# Claude APIを使う場合のみ設定
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Market Data Provider
# -----------------------------------------------------------------------------
# アクティブな価格データプロバイダーを選択する
#
# oanda    : OANDA v20 REST API（互換副系・デフォルト）
# dukascopy: Dukascopy 公開 candle API（研究主系・高精度履歴）
#
# Dukascopy に切り替える場合:
#   1. MARKET_DATA_ACTIVE_PROVIDER=dukascopy に変更
#   2. DUKASCOPY_ENABLED=true に変更
#   ※ OANDA への切り戻しは MARKET_DATA_ACTIVE_PROVIDER=oanda に戻すだけでよい
MARKET_DATA_ACTIVE_PROVIDER=oanda

# Dukascopy（研究主系・DUKASCOPY_ENABLED=true で有効化）
DUKASCOPY_ENABLED=false
DUKASCOPY_BASE_URL=https://freeserv.dukascopy.com/2.0


# -----------------------------------------------------------------------------
# OANDA API（互換副系 / MARKET_DATA_ACTIVE_PROVIDER=oanda 時に使用）
# -----------------------------------------------------------------------------
OANDA_API_KEY=
OANDA_ACCOUNT_ID=