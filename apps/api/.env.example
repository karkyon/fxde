# =============================================================================
# FXDE API Environment Template
# -----------------------------------------------------------------------------
# NestJS API が使用する環境変数テンプレート
#
# 使用方法
#   cp .env.example .env
# =============================================================================


# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

DATABASE_URL="postgresql://fxde:fxde_password@localhost:5436/fxde_db"


# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
# BullMQ / queue 接続

REDIS_URL=redis://localhost:6386


# -----------------------------------------------------------------------------
# API Server
# -----------------------------------------------------------------------------

NODE_ENV=development
PORT=3011
API_PREFIX=/api/v1


# -----------------------------------------------------------------------------
# JWT
# -----------------------------------------------------------------------------

JWT_SECRET=replace_this_with_secure_value
JWT_EXPIRES_IN=15m

JWT_REFRESH_SECRET=replace_this_with_secure_value
REFRESH_TOKEN_EXPIRES_IN=7d


# -----------------------------------------------------------------------------
# Frontend origin
# -----------------------------------------------------------------------------

FRONTEND_URL=http://localhost:5173


# -----------------------------------------------------------------------------
# AI Summary (optional)
# -----------------------------------------------------------------------------
# Claude APIを使う場合のみ設定

ANTHROPIC_API_KEY=