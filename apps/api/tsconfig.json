{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "module": "commonjs",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "paths": {
      "@fxde/types": [
        "../../packages/types/dist"
      ],
      "@fxde/types/*": [
        "../../packages/types/dist/*"
      ],
      "@fxde/config": [
        "../../packages/config/dist"
      ]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "../../prisma/seed.ts",
    "../../prisma/*.ts"
  ]
}