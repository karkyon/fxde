# =============================================================================
# FXDE Root Environment Template
# -----------------------------------------------------------------------------
# このファイルはリポジトリルートの開発ツール用テンプレート
#
# 使用主体
#   - Prisma CLI
#   - docker compose
#   - pnpm scripts
#
# 実際に使用する場合
#   cp .env.example .env
# =============================================================================


# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# PostgreSQL connection
# host: localhost
# port: 5436 (host) → 5432 (container)

DATABASE_URL="postgresql://fxde:fxde_password@localhost:5436/fxde_db"


# -----------------------------------------------------------------------------
# Redis
# ⚠️ REDIS_HOST / REDIS_PORT は使用しない。REDIS_URL に統一
# port: 6386 (host) → 6379 (container)
# -----------------------------------------------------------------------------
# Redis connection

REDIS_URL=redis://localhost:6386


# -----------------------------------------------------------------------------
# Environment
# -----------------------------------------------------------------------------

NODE_ENV=development

# -----------------------------------------------------------------------------
# JWT Settings
# -----------------------------------------------------------------------------
JWT_SECRET=change-me-in-production-min-32-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# -----------------------------------------------------------------------------
# Frontend origin
# ⚠️ API_PORT ではなく PORT を使用すること（main.ts は PORT を読む）
# -----------------------------------------------------------------------------
# APIのCORS許可用

PORT=3011
FRONTEND_URL=http://localhost:5173

# -----------------------------------------------------------------------------
# Frontend (apps/web/.env にコピーして使用)
# -----------------------------------------------------------------------------
# ⚠️ /api/v1 を含めないこと
#    api.ts が baseURL: `${VITE_API_BASE_URL}/api/v1` を組み立てる
VITE_API_BASE_URL=http://localhost:3011

# -----------------------------------------------------------------------------
# Market Data Provider（Phase 2: Dukascopy 対応）
# -----------------------------------------------------------------------------
# oanda    : OANDA v20 REST API（互換副系・デフォルト）
# dukascopy: Dukascopy 公開 candle API（研究主系）
# Dukascopy 有効化: MARKET_DATA_ACTIVE_PROVIDER=dukascopy かつ DUKASCOPY_ENABLED=true
# ⚠️ Dukascopy M5 / M1 注意: 短期足は空レスポンスが頻発するため market_candles が埋まらない。
#    研究主系として使用する場合は H4 / D1 / W1 を中心とすること。
#    M5 でデータが必要な場合は MARKET_DATA_ACTIVE_PROVIDER=oanda に切り替えること。
MARKET_DATA_ACTIVE_PROVIDER=oanda
DUKASCOPY_ENABLED=false
DUKASCOPY_BASE_URL=https://freeserv.dukascopy.com/2.0